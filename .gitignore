# Зависимости
node_modules/
.pnp/
.pnp.js

# Сборочные директории Next.js
.next/
out/ # Для экспортированных статических сайтов

# Локальные переменные окружения (НЕ должны быть в репозитории!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# Лог-файлы пакетных менеджеров
npm-debug.log*
yarn-debug.log*
yarn-error.log

# Файлы операционных систем и IDE
.DS_Store # macOS
Thumbs.db # Windows
.vscode/ # Настройки VS Code (опционально, если не хочешь делиться)

# TypeScript кэш (если используешь TypeScript)
*.tsbuildinfo

# Файлы Vercel CLI (если деплоишь на Vercel)
.vercel/