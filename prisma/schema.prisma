// prisma/schema.prisma

// Генератор клиента Prisma для JavaScript
generator client {
  provider = "prisma-client-js"
}

// Источник данных для подключения к базе данных SQLite
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // Получает URL базы данных из переменных окружения
}

// Модель Tour (туры)
model Tour {
  // id тура, генерируется UUID по умолчанию, хранится как TEXT в SQLite
  id          String    @id @default(uuid()) @map("id") 
  // Название тура, обязательное поле
  title       String
  // Описание тура, может быть пустым
  description String?   
  // Цена тура, число с плавающей точкой
  price       Float     
  // Валюта, по умолчанию "BYN"
  currency    String    @default("BYN")
  // Категория тура, по умолчанию "hot"
  category    String    @default("hot")
  // URL изображения, путь к локальному файлу
  image_url   String
  // Время создания записи, устанавливается автоматически
  createdAt   DateTime  @default(now()) @map("created_at")
  // Время последнего обновления записи, обновляется автоматически
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  // Соответствие имени таблицы в базе данных
  @@map("tours")
}

// Модель Review (отзывы)
model Review {
  // id отзыва, генерируется UUID по умолчанию, хранится как TEXT в SQLite
  id          String    @id @default(uuid()) @map("id") 
  // Автор отзыва
  author      String
  // Текст отзыва, обязательное поле
  text        String
  // Дата создания отзыва, устанавливается автоматически
  date        DateTime  @default(now())
  // Статус отзыва ('pending' - на модерации, 'published' - опубликован), по умолчанию "pending"
  status      String    @default("pending")
  // Время последнего обновления записи, обновляется автоматически
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_ad")

  // Соответствие имени таблицы в базе данных
  @@map("reviews")
}

// НОВАЯ МОДЕЛЬ: AdminUser (для управления администраторами)
model AdminUser {
  // id пользователя, генерируется UUID по умолчанию, хранится как TEXT в SQLite
  id            String    @id @default(uuid()) @map("id")
  // Email пользователя, должен быть уникальным
  email         String    @unique @map("email")
  // Хеш пароля пользователя (обязательно хешированный)
  passwordHash  String    @map("password_hash")
  // Роль пользователя ('admin' или 'super_admin'), по умолчанию 'admin'
  role          String    @default("admin") @map("role")
  // Время создания записи
  createdAt     DateTime  @default(now()) @map("created_at")
  // Время последнего обновления записи
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  // Соответствие имени таблицы в базе данных
  @@map("admin_users")
}
